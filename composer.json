{
  "name": "pronskiy/phpup",
  "description": "The PHP toolchain installer",
  "keywords": [
    "php",
    "toolchain",
    "composer"
  ],
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "type": "project",
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/pronskiy/conductor.git"
    }
  ],
  "require": {
    "php": "^8.3",
    "composer/composer": "^2.7.3",
    "symfony/var-dumper": "^7.0.6",
    "symfony/console": "^7.0",
    "cweagans/composer-patches": "^2.0.0-beta2",
    "pronskiy/locus": "^0.2",
    "artisan-build/conductor": "@dev"
  },
  "require-dev": {
    "humbug/box": "^4.6",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Pronskiy\\Phpup\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Pronskiy\\Phpup\\Tests\\": "tests/"
    }
  },
  "extra": {
    "patches": {
      "symfony/var-dumper": {
        "Fix SAPI": "patches/symfony/var-dumper.patch"
      },
      "composer/composer": {
        "Fix SAPI": "patches/composer/composer.patch"
      }
    }
  },
  "config": {
    "allow-plugins": {
      "cweagans/composer-patches": true,
      "pronskiy/locus": false
    },
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "build": "./build.sh"
  }
}
