{
  "directories": [
    "src"
  ],
  "files": [
    "vendor/autoload.php"
  ],
  "finder": [
    {
      "name": "*.php",
      "exclude": [
        "test",
        "tests",
        "Test",
        "Tests",
        "doc",
        "docs"
      ],
      "in": "vendor"
    }
  ],
  "compression": "GZ",
  "compactors": [
    "KevinGH\\Box\\Compactor\\Php"
  ],
  "main": "index.php",
  "output": "build/index.phar"
}